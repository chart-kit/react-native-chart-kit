{
  "name": "@chart-kit/skia-renderer",
  "version": "7.0.0-next.0",
  "description": "Preview Skia renderer boundary for Chart Kit v2 Pro experiments.",
  "repository": {
    "type": "git",
    "url": "https://github.com/indiespirit/react-native-chart-kit",
    "directory": "packages/skia-renderer"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=1.5.0 <3",
    "react": ">=19.2.0 <20",
    "react-native": ">=0.83 <1"
  },
  "peerDependenciesMeta": {
    "@shopify/react-native-skia": {
      "optional": true
    }
  },
  "license": "MIT"
}
