{
  "name": "@chart-kit/react-native",
  "version": "7.0.0",
  "private": true,
  "description": "Modern React Native chart components assembled into the public react-native-chart-kit package.",
  "keywords": [
    "react-native",
    "chart-kit",
    "charts",
    "charting",
    "data-visualization",
    "line-chart",
    "bar-chart",
    "pie-chart",
    "progress-chart",
    "dashboard",
    "analytics",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chart-kit/react-native-chart-kit",
    "directory": "packages/react-native"
  },
  "homepage": "https://chartkit.io",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@chart-kit/core": "7.0.0",
    "@chart-kit/svg-renderer": "7.0.1"
  },
  "peerDependencies": {
    "react": ">=19.1.0 <20",
    "react-native": ">=0.81 <1",
    "react-native-svg": ">=15.12.1 <16"
  },
  "license": "MIT",
  "author": "Berman Digital Ltd",
  "bugs": {
    "url": "https://github.com/chart-kit/react-native-chart-kit/issues"
  }
}
