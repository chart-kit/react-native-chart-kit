<script
  type="application/json"
  id="pro-pricing-data"
  is:inline
  set:html={JSON.stringify(proTiersByKey)}
/>

<script>
  type ProPricingTier = {
    cadence: string;
    cta: string;
    description: string;
    features: string[];
    href: string;
    name: string;
    price: string;
    productId: string;
  };

  const hydrateProPricing = () => {
    const root = document.querySelector("[data-pro-pricing]");
    const dataNode = document.querySelector("#pro-pricing-data");

    if (!root || !dataNode?.textContent) {
      return;
    }

    const tiers = JSON.parse(dataNode.textContent) as Record<
      string,
      ProPricingTier
    >;
    const buttons = Array.from(
      root.querySelectorAll<HTMLButtonElement>("[data-pro-tier]")
    );
    const planName = root.querySelector("[data-pro-plan-name]");
    const price = root.querySelector("[data-pro-price]");
    const cadence = root.querySelector("[data-pro-cadence]");
    const description = root.querySelector("[data-pro-description]");
    const features = root.querySelector("[data-pro-features]");
    const cta = root.querySelector("[data-pro-cta]");
    const indicator = root.querySelector<HTMLElement>(
      "[data-pro-tier-indicator]"
    );

    const renderFeature = (feature: string) => `
      <li class="flex items-center gap-3 text-sm font-medium text-white/62 transition-colors duration-300 [html[data-theme='light']_&]:text-black/62">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 rounded-full text-white/70 [html[data-theme='light']_&]:text-black/66">
          <path d="M20 6 9 17l-5-5"></path>
        </svg>
        <span>${feature}</span>
      </li>
    `;

    const selectTier = (key?: string) => {
      if (!key) {
        return;
      }

      const tier = tiers[key];

      if (!tier) {
        return;
      }

      buttons.forEach((button) => {
        const selected = button.dataset.proTier === key;
        button.dataset.selected = String(selected);
        button.setAttribute("aria-pressed", String(selected));
      });

      const selectedIndex = buttons.findIndex(
        (button) => button.dataset.proTier === key
      );

      if (indicator && selectedIndex >= 0) {
        indicator.style.transform = `translateX(${selectedIndex * 100}%)`;
      }

      if (planName) planName.textContent = `${tier.name} license`;
      if (price) price.textContent = tier.price;
      if (cadence) cadence.textContent = tier.cadence;
      if (description) description.textContent = tier.description;
      if (features)
        features.innerHTML = tier.features.map(renderFeature).join("");
      if (cta) {
        cta.textContent = tier.cta;
        cta.setAttribute("href", tier.href);
      }
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () =>
        selectTier(button.dataset.proTier)
      );
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", hydrateProPricing, {
      once: true
    });
  } else {
    hydrateProPricing();
  }
</script>

<style>
  [data-pro-pricing] > :not(.pro-card-border-trail) {
    position: relative;
    z-index: 1;
  }

  .pricing-card-header {
    margin: -1.25rem -1.25rem 0;
    border-bottom: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 1rem 1rem 0 0;
    background: rgb(255 255 255 / 0.055);
    padding: 1.125rem 1.25rem 1rem;
    transition:
      background-color 300ms ease,
      border-color 300ms ease;
  }

  [data-pro-pricing] .pricing-card-header {
    background: rgb(255 255 255 / 0.075);
  }

  :global(html[data-theme="light"]) .pricing-card-header {
    border-bottom-color: rgb(0 0 0 / 0.1);
    background: rgb(0 0 0 / 0.04);
  }

  :global(html[data-theme="light"]) [data-pro-pricing] .pricing-card-header {
    background: rgb(0 0 0 / 0.055);
  }

  .pro-card-border-trail {
    pointer-events: none;
    position: absolute;
    inset: 0;
    z-index: 0;
    border: 1px solid transparent;
    border-radius: inherit;
    mask-clip: padding-box, border-box;
    mask-composite: intersect;
    mask-image:
      linear-gradient(transparent, transparent), linear-gradient(#000, #000);
    -webkit-mask-clip: padding-box, border-box;
    -webkit-mask-composite: source-in;
    -webkit-mask-image:
      linear-gradient(transparent, transparent), linear-gradient(#000, #000);
  }

  .pro-card-border-trail-runner {
    position: absolute;
    width: 100px;
    aspect-ratio: 1;
    background: rgb(113 113 122);
    box-shadow:
      0 0 60px 30px rgb(255 255 255 / 0.5),
      0 0 100px 60px rgb(0 0 0 / 0.5),
      0 0 140px 90px rgb(0 0 0 / 0.5);
    offset-distance: 0%;
    offset-path: rect(0 auto auto 0 round 100px);
    animation: pro-card-border-trail 5s linear infinite;
  }

  @keyframes pro-card-border-trail {
    to {
      offset-distance: 100%;
    }
  }

  .pro-tier-button {
    min-height: 1.625rem;
    border-radius: 999px;
    color: rgb(255 255 255 / 0.58);
    cursor: pointer;
    font-size: 0.6875rem;
    font-weight: 700;
    position: relative;
    z-index: 1;
    transition: color 180ms ease;
  }

  .pro-tier-button:hover {
    color: rgb(255 255 255 / 0.88);
  }

  .pro-tier-button[data-selected="true"] {
    color: rgb(0 0 0 / 0.88);
  }

  :global(html[data-theme="light"]) .pro-tier-button {
    color: rgb(0 0 0 / 0.58);
  }

  :global(html[data-theme="light"]) .pro-tier-button:hover {
    color: rgb(0 0 0 / 0.88);
  }

  :global(html[data-theme="light"]) .pro-tier-button[data-selected="true"] {
    color: rgb(255 255 255 / 0.92);
  }

  @media (prefers-reduced-motion: reduce) {
    .pro-card-border-trail-runner {
      animation: none;
    }
  }

  @media (min-width: 640px) {
    .pricing-card-header {
      margin: -1.5rem -1.5rem 0;
      padding: 1.25rem 1.5rem 1.125rem;
    }
  }
</style>
