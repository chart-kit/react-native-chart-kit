---
import "../../styles/global.css";
import {
  ArrowRight,
  Check,
  Mail,
  ReceiptText,
  ShieldCheck
} from "lucide-astro";
import FaviconLinks from "../../components/FaviconLinks.astro";
import Footer from "../../components/Footer.astro";
import GoogleAnalytics from "../../components/GoogleAnalytics.astro";
import Header from "../../components/Header.astro";
import SocialImageMeta from "../../components/SocialImageMeta.astro";
import ThemeInit from "../../components/ThemeInit.astro";

const pageTitle = "Checkout complete - Chart Kit Pro";
const pageDescription =
  "Your Chart Kit Pro checkout is complete. Your license certificate and setup details are on the way.";
const pageUrl = "https://chartkit.io/checkout/success/";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#06070a" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="React Native Chart Kit" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <SocialImageMeta />
    <FaviconLinks />
    <ThemeInit />
    <GoogleAnalytics />
  </head>
  <body class="landing-page">
    <Header homeHrefPrefix="/" />
    <main
      class="relative min-h-screen overflow-hidden bg-black text-white transition-colors duration-300 [html[data-theme='light']_&]:bg-white [html[data-theme='light']_&]:text-black"
    >
      <section
        id="checkout-success"
        class="relative mx-auto grid min-h-screen w-full max-w-[1320px] grid-cols-1 items-center gap-12 px-6 pt-28 pb-16 sm:px-8 md:px-10 lg:grid-cols-[minmax(0,640px)_minmax(300px,420px)] lg:gap-16 lg:px-12 xl:px-16"
      >
        <div
          class="pointer-events-none absolute inset-x-6 top-24 bottom-12 border-x border-white/[0.06] transition-colors duration-300 [html[data-theme='light']_&]:border-black/[0.06] sm:inset-x-8 md:inset-x-10 lg:inset-x-12 xl:inset-x-16"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute inset-x-0 top-[46%] h-px bg-gradient-to-r from-transparent via-white/14 to-transparent transition-colors duration-300 [html[data-theme='light']_&]:via-black/12"
          aria-hidden="true"
        >
        </div>

        <div class="relative z-10 max-w-[670px]">
          <div
            class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.035] px-3 py-1.5 text-xs font-semibold text-white/70 backdrop-blur-xl transition-colors duration-300 [html[data-theme='light']_&]:border-black/10 [html[data-theme='light']_&]:bg-black/[0.035] [html[data-theme='light']_&]:text-black/62"
          >
            <span
              class="inline-flex size-5 items-center justify-center rounded-full bg-[#0f7b55] text-white"
            >
              <Check size={13} stroke-width={3} aria-hidden="true" />
            </span>
            Payment received
          </div>

          <h1
            class="mt-8 max-w-4xl text-5xl font-semibold leading-[1.04] text-white transition-colors duration-300 sm:text-6xl lg:text-7xl [html[data-theme='light']_&]:text-black"
          >
            You're all set.
          </h1>

          <p
            class="mt-7 max-w-[590px] text-base leading-7 text-white/60 transition-colors duration-300 [html[data-theme='light']_&]:text-black/60"
          >
            Polar is confirming the order. Your Chart Kit Pro license
            certificate, license key, and setup notes will be emailed shortly.
          </p>

          <div class="mt-10 flex flex-col gap-3 sm:flex-row">
            <a
              href="/docs/react-native"
              class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-white px-5 text-sm font-semibold text-black shadow-[0_16px_36px_rgba(255,255,255,0.14)] ring-1 ring-white/20 transition-all hover:-translate-y-px hover:bg-white/92 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white/45 active:translate-y-0 [html[data-theme='light']_&]:bg-black [html[data-theme='light']_&]:text-white [html[data-theme='light']_&]:shadow-[0_16px_36px_rgba(0,0,0,0.12)] [html[data-theme='light']_&]:ring-black/10 [html[data-theme='light']_&]:focus-visible:outline-black/40"
            >
              Open docs
              <ArrowRight size={16} stroke-width={2.25} aria-hidden="true" />
            </a>
            <a
              href="mailto:sales@chartkit.io"
              class="inline-flex h-11 items-center justify-center gap-2 rounded-full border border-white/12 px-5 text-sm font-semibold text-white/72 transition-all hover:-translate-y-px hover:border-white/22 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white/45 active:translate-y-0 [html[data-theme='light']_&]:border-black/12 [html[data-theme='light']_&]:text-black/70 [html[data-theme='light']_&]:hover:border-black/22 [html[data-theme='light']_&]:hover:text-black [html[data-theme='light']_&]:focus-visible:outline-black/40"
            >
              <Mail size={16} stroke-width={2.25} aria-hidden="true" />
              Contact sales
            </a>
          </div>
        </div>

        <aside class="relative z-10" aria-label="Checkout follow-up">
          <div
            class="rounded-[28px] border border-white/10 bg-white/[0.035] p-6 shadow-[0_28px_90px_rgba(0,0,0,0.36)] backdrop-blur-xl transition-colors duration-300 [html[data-theme='light']_&]:border-black/10 [html[data-theme='light']_&]:bg-black/[0.035] [html[data-theme='light']_&]:shadow-[0_28px_90px_rgba(0,0,0,0.09)]"
          >
            <div class="flex items-start justify-between gap-5">
              <div>
                <p
                  class="text-xs font-semibold text-white/38 uppercase transition-colors duration-300 [html[data-theme='light']_&]:text-black/38"
                >
                  Chart Kit Pro
                </p>
                <h2
                  class="mt-3 text-2xl font-semibold text-white transition-colors duration-300 [html[data-theme='light']_&]:text-black"
                >
                  License delivery
                </h2>
              </div>
              <img
                src="/images/logo.svg"
                alt=""
                class="mt-1 h-10 w-auto"
                loading="eager"
                decoding="async"
                aria-hidden="true"
              />
            </div>

            <div
              class="mt-6 border-t border-white/10 pt-4 transition-colors duration-300 [html[data-theme='light']_&]:border-black/10"
            >
              <p
                class="text-xs font-medium text-white/42 transition-colors duration-300 [html[data-theme='light']_&]:text-black/42"
              >
                Checkout ID
              </p>
              <p
                data-checkout-id
                class="mt-1 truncate text-sm font-semibold text-white/82 transition-colors duration-300 [html[data-theme='light']_&]:text-black/82"
              >
                Processing
              </p>
            </div>

            <ol class="mt-6 space-y-4">
              <li class="flex gap-3">
                <span
                  class="mt-0.5 inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-[#0f7b55] text-white"
                >
                  <Check size={15} stroke-width={3} aria-hidden="true" />
                </span>
                <div>
                  <p
                    class="text-sm font-semibold text-white [html[data-theme='light']_&]:text-black"
                  >
                    Order confirmed
                  </p>
                  <p
                    class="mt-1 text-sm leading-5 text-white/45 [html[data-theme='light']_&]:text-black/45"
                  >
                    Polar has accepted the checkout and will send the receipt.
                  </p>
                </div>
              </li>
              <li class="flex gap-3">
                <span
                  class="mt-0.5 inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-white/8 text-white/72 ring-1 ring-white/10 [html[data-theme='light']_&]:bg-black/5 [html[data-theme='light']_&]:text-black/68 [html[data-theme='light']_&]:ring-black/10"
                >
                  <ShieldCheck
                    size={15}
                    stroke-width={2.35}
                    aria-hidden="true"
                  />
                </span>
                <div>
                  <p
                    class="text-sm font-semibold text-white [html[data-theme='light']_&]:text-black"
                  >
                    License generated
                  </p>
                  <p
                    class="mt-1 text-sm leading-5 text-white/45 [html[data-theme='light']_&]:text-black/45"
                  >
                    Your key and PDF certificate are created from the order.
                  </p>
                </div>
              </li>
              <li class="flex gap-3">
                <span
                  class="mt-0.5 inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-white/8 text-white/72 ring-1 ring-white/10 [html[data-theme='light']_&]:bg-black/5 [html[data-theme='light']_&]:text-black/68 [html[data-theme='light']_&]:ring-black/10"
                >
                  <ReceiptText
                    size={15}
                    stroke-width={2.35}
                    aria-hidden="true"
                  />
                </span>
                <div>
                  <p
                    class="text-sm font-semibold text-white [html[data-theme='light']_&]:text-black"
                  >
                    Email on the way
                  </p>
                  <p
                    class="mt-1 text-sm leading-5 text-white/45 [html[data-theme='light']_&]:text-black/45"
                  >
                    Look for a message from licenses@chartkit.io.
                  </p>
                </div>
              </li>
            </ol>

            <div
              class="mt-7 overflow-hidden border-t border-white/10 pt-4 transition-colors duration-300 [html[data-theme='light']_&]:border-black/10"
            >
              <p
                class="text-[11px] font-semibold text-white/38 transition-colors duration-300 [html[data-theme='light']_&]:text-black/38"
              >
                Install
              </p>
              <pre
                class="mt-2 overflow-x-auto text-[12px] leading-5 text-white/78 [font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace] [html[data-theme='light']_&]:text-black/78"><code>npm install react-native-chart-kit @chart-kit/pro react-native-svg</code></pre>
            </div>
          </div>
        </aside>
      </section>
    </main>
    <Footer homeHrefPrefix="/" />
    <script>
      const checkoutId = new URLSearchParams(window.location.search).get(
        "checkout_id"
      );
      const target = document.querySelector("[data-checkout-id]");

      if (target) {
        target.textContent = checkoutId || "Available in your Polar receipt";
      }
    </script>
  </body>
</html>
